{
  "name": "zigchain-staking-monitor",
  "version": "1.0.0",
  "description": "ZigChain wallet monitor: alerts on sends, IBC transfers, contract calls, delegate/undelegate/redelegate",
  "type": "module",
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "replay": "tsx scripts/replay.ts"
  },
  "dependencies": {
    "@cosmjs/encoding": "^0.32.4",
    "cosmjs-types": "^0.9.0",
    "dotenv": "^16.4.5",
    "googleapis": "^173.0.0",
    "telegraf": "^4.16.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
