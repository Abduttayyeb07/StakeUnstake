# ZigChain endpoints — comma-separated, first is primary, rest are fallbacks
RPC_URL= Rpc url 
WS_URL= websocket url 

# Wallet(s) to monitor, comma-separated. Optional "Name:" prefix labels the
# wallet in alerts and /balances (e.g. "Deal 1:zig1wrje0m...,Deal 2:zig1qqre8...").
WALLET_ADDRESS= tracked wallet address(es)

# Telegram (leave TELEGRAM_BOT_TOKEN empty to print alerts to console instead)
TELEGRAM_BOT_TOKEN=
# Optional: chat ids always alerted, comma-separated (users can also /start the bot)
TELEGRAM_CHAT_ID=
# Private chat id for operational/health messages (WS reconnects, stale connections) — not broadcast to TELEGRAM_CHAT_ID
ADMIN_CHAT_ID=

# Optional tuning
POLL_INTERVAL_MS=10000
# tx_search reconciliation sweep interval (safety net behind the block pipeline)
BACKFILL_INTERVAL_MS=300000
STATE_FILE=state.json
BACKFILL_STATE_FILE=backfill-state.json
DEDUPE_FILE=alerts-seen.json
SUBSCRIBERS_FILE=subscribers.json
EXPLORER_TX_URL=https://www.zigscan.org/tx/

# Google Sheets logging (optional — leave GOOGLE_CREDENTIALS_PATH empty to disable).
# Once a day at 00:00 PKT, a snapshot row (ZIG balance, stZIG balance, total
# delegation, pending rewards) is appended to the sheet tab named after the
# wallet's WALLET_ADDRESS label above (e.g. "Deal 1"), so each labeled wallet
# needs a matching tab in the spreadsheet. Independent of Telegram alerting.
GOOGLE_CREDENTIALS_PATH=./fit-sanctum-478115-c1-828f08dbfbde.json
GOOGLE_SPREADSHEET_ID=https://docs.google.com/spreadsheets/d/1f2nKY0xW89B59k3mBtVd0ZhWWv5esRNAoObPztt6mSg/edit
STZIG_DENOM=coin.zig109f7g2rzl2aqee7z6gffn8kfe9cpqx0mjkk7ethmx8m2hq4xpe9snmaam2.stzig
SNAPSHOT_STATE_FILE=snapshot-state.json

# --- Ethereum ZIG-token wallet monitor (separate chain, reuses the same Telegram bot) ---
# Leave WATCHED_WALLETS empty to disable this monitor entirely.
ETH_RPC_URLS=https://eth.llamarpc.com,https://ethereum.publicnode.com,https://rpc.ankr.com/eth,https://cloudflare-eth.com,https://eth-mainnet.public.blastapi.io,https://1rpc.io/eth,https://rpc.flashbots.net,https://endpoints.omniatech.io/v1/eth/mainnet/public
ETH_WS_URLS=wss://ethereum.publicnode.com,wss://eth.llamarpc.com
# "Label=0xAddress", comma-separated for multiple wallets
WATCHED_WALLETS=Deal 1 (eth)=0x12d4Af7f9D4d369d81e4b033585Be24929e95b35
# verified live on-chain: ZigCoin (ZIG), 18 decimals, at this checksummed address —
# don't change unless the protocol issues a new contract
ZIG_TOKEN_ADDRESS=0xb2617246d0c6c0087f18703d576831899ca94f01
TOKEN_SYMBOL=ZIG
TOKEN_DECIMALS=18
MIN_ALERT_AMOUNT=0
ALERT_INCOMING=true
ALERT_OUTGOING=true
ETH_POLL_INTERVAL_MS=15000
CONFIRMATIONS=1
MAX_BLOCK_RANGE=2000
MAX_BACKLOG_BLOCKS=50000
ETH_JUMP_TO_TIP_ON_BOOT=false
ETH_STATE_FILE=eth-state.json
ETH_SNAPSHOT_STATE_FILE=eth-snapshot-state.json
ETHERSCAN_API_KEY=
ETHERSCAN_TX_URL=https://etherscan.io/tx/
