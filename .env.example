# ZigChain endpoints — comma-separated, first is primary, rest are fallbacks
RPC_URL= Rpc url 
WS_URL= websocket url 

# Wallet(s) to monitor, comma-separated
WALLET_ADDRESS= tracked wallet address 

# Telegram (leave TELEGRAM_BOT_TOKEN empty to print alerts to console instead)
TELEGRAM_BOT_TOKEN=
# Optional: chat ids always alerted, comma-separated (users can also /start the bot)
TELEGRAM_CHAT_ID=

# Optional tuning
POLL_INTERVAL_MS=10000
# tx_search reconciliation sweep interval (safety net behind the block pipeline)
BACKFILL_INTERVAL_MS=300000
STATE_FILE=state.json
BACKFILL_STATE_FILE=backfill-state.json
DEDUPE_FILE=alerts-seen.json
SUBSCRIBERS_FILE=subscribers.json
EXPLORER_TX_URL=https://www.zigscan.org/tx/
